    <dependencies>
      <group targetFramework=".NETFramework4.7.2">
        <dependency id="CitizenFX.Core.Server" version="1.0.26803" />
        <dependency id="YamlDotNet" version="18.1.0" />
      </group>
    </dependencies>
  </metadata>
  <files>
