<?xml version="1.0" encoding="utf-8"?>
<Project xmlns="http://schemas.microsoft.com/developer/msbuild/2003">

  <PropertyGroup>
    <!-- Turn off Microsoft.NET.Test.Sdk's auto-generated entrypoint -->
    <GenerateProgramFile>false</GenerateProgramFile>
    <!-- Turn on Microsoft.Testing.Platform.MSBuild's auto-generated registration function -->
    <GenerateSelfRegisteredExtensions>true</GenerateSelfRegisteredExtensions>
    <!-- Turn off Microsoft.Testing.Platform.MSBuild's auto-generated entrypoint -->
    <GenerateTestingPlatformEntryPoint>false</GenerateTestingPlatformEntryPoint>
    <!-- Turn on the flag that indicates this is a Microsoft.Testing.Platform project -->
    <IsTestingPlatformApplication Condition=" '$(IsTestingPlatformApplication)' == '' ">true</IsTestingPlatformApplication>
    <TestProject>true</TestProject>
    <!-- Force the app host for .NET builds, since it's required for xunit.v3.runner.utility to run v3 projects -->
    <UseAppHost>true</UseAppHost>
    <!-- Signal that this is an xUnit.net test project -->
    <XunitTestProject>true</XunitTestProject>
    <XunitTestProjectAOT>false</XunitTestProjectAOT>
    <XunitTestProjectAOT Condition="$(MSBuildThisFileName.Contains('.aot'))">true</XunitTestProjectAOT>
  </PropertyGroup>

  <ItemGroup>
    <!-- Give the code generator access to the project path and whether we're in AOT mode -->
    <CompilerVisibleProperty Include="MSBuildProjectFullPath;XunitTestProjectAOT" />
  </ItemGroup>

</Project>
